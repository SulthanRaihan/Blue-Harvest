# Salin file ini ke .env.local dan isi dengan nilai dari Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx...

# Service Role Key — JANGAN pakai prefix NEXT_PUBLIC_, hanya untuk server-side
# Ambil dari Supabase > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...
